# Octopus Energy API Configuration

# Your Octopus Energy API key (required)
# Get this from: https://octopus.energy/dashboard/developer/
OCTOPUS_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx

# Your Octopus Energy account number (required)
# Format: A-XXXXXXXX
# Find this on your Octopus Energy bill or account dashboard
OCTOPUS_ACCOUNT_NUMBER=A-XXXXXXXX

# Octopus Energy API base URL (optional)
# Default: https://api.octopus.energy/v1
# Only change if using a different API endpoint
OCTOPUS_API_BASE_URL=https://api.octopus.energy/v1
